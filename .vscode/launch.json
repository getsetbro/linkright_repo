{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch LinkRight",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/LinkRight/LinkRight",
      "buildFlags": "-tags=desktop",
      "cwd": "${workspaceFolder}/LinkRight/LinkRight"
    },
    {
      "name": "Launch LinkRight (with URL)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/LinkRight/LinkRight",
      "args": ["https://example.com"],
      "buildFlags": "-tags=desktop",
      "cwd": "${workspaceFolder}/LinkRight/LinkRight"
    }
  ]
}
