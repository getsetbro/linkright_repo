{
  "schema_version": 1,
  "updated": "2025-06-10",
  "notes": "Browser definitions for LinkRight. This file can be updated remotely without rebuilding the app.",

  "browser_types": {
    "chromium": {
      "launch_flags": ["--profile-directory=${profileId}", "${url}"],
      "launch_flags_no_profile": ["${url}"],
      "user_data_dirs": {
        "chrome": "${LOCALAPPDATA}/Google/Chrome/User Data",
        "chrome_dev": "${LOCALAPPDATA}/Google/Chrome Dev/User Data",
        "chrome_sxs": "${LOCALAPPDATA}/Google/Chrome SxS/User Data",
        "chrome_beta": "${LOCALAPPDATA}/Google/Chrome Beta/User Data",
        "edge": "${LOCALAPPDATA}/Microsoft/Edge/User Data",
        "brave": "${LOCALAPPDATA}/BraveSoftware/Brave-Browser/User Data",
        "opera": "${LOCALAPPDATA}/Opera Software/Opera Stable",
        "vivaldi": "${LOCALAPPDATA}/Vivaldi/User Data",
        "arc": "${LOCALAPPDATA}/TheBrowserCompany/Arc/User Data"
      },
      "channel_detection": [
        { "path_contains": "chrome dev", "data_dir_key": "chrome_dev" },
        { "path_contains": "chrome sxs", "data_dir_key": "chrome_sxs" },
        { "path_contains": "chrome beta", "data_dir_key": "chrome_beta" },
        { "path_contains": "msedge", "data_dir_key": "edge" },
        { "path_contains": "edge", "data_dir_key": "edge" },
        { "path_contains": "brave", "data_dir_key": "brave" },
        { "path_contains": "opera", "data_dir_key": "opera" },
        { "path_contains": "vivaldi", "data_dir_key": "vivaldi" },
        { "path_contains": "chrome", "data_dir_key": "chrome" }
      ],
      "type_detection": [
        "chrome", "edge", "brave", "opera", "vivaldi", "arc"
      ]
    },
    "firefox": {
      "launch_flags": ["--allow-downgrade", "--profile", "${profilePath}", "${url}"],
      "launch_flags_no_profile": ["${url}"],
      "profile_dirs": {
        "standard": "${APPDATA}/Mozilla/Firefox",
        "developer": "${APPDATA}/Mozilla/Firefox Developer Edition"
      },
      "developer_path_indicators": ["developer edition", "firefox dev"],
      "type_detection": ["firefox"]
    }
  },

  "type_detection_rules": [
    { "name_or_path_contains": "firefox", "type": "firefox" },
    { "name_or_path_contains": "chrome", "type": "chromium" },
    { "name_or_path_contains": "edge", "type": "chromium" },
    { "name_or_path_contains": "brave", "type": "chromium" },
    { "name_or_path_contains": "opera", "type": "chromium" },
    { "name_or_path_contains": "vivaldi", "type": "chromium" },
    { "name_or_path_contains": "thebrowsercompany.arc", "type": "chromium" },
    { "name_equals": "arc", "type": "chromium" },
    { "path_ends_with": "\\arc.exe", "type": "chromium" },
    { "path_ends_with": "/arc.exe", "type": "chromium" }
  ],

  "msix_browsers": [
    {
      "exe_name": "Arc.exe",
      "display_name": "Arc",
      "package_family_id": "TheBrowserCompany.Arc_ttt1ap7aakyb4",
      "browser_type": "chromium"
    },
    {
      "exe_name": "DuckDuckGo.exe",
      "display_name": "DuckDuckGo",
      "package_family_id": "DuckDuckGo.DesktopBrowser_ya2fgkz3nks94",
      "browser_type": "other"
    }
  ]
}
